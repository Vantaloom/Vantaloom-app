{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Vantaloom",
  "version": "0.6.0",
  "identifier": "online.timefiles.vantaloom",
  "build": {
    "frontendDist": "../web"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Vantaloom",
        "width": 420,
        "height": 880
      }
    ],
    "security": {
      "csp": null,
      "dangerousUseHttpScheme": true
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png"
    ],
    "createUpdaterArtifacts": false
  },
  "plugins": {}
}
