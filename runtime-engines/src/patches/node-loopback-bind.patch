diff --git a/src/tcp_wrap.cc b/src/tcp_wrap.cc
--- a/src/tcp_wrap.cc
+++ b/src/tcp_wrap.cc
@@ -62,6 +62,27 @@ using v8::String;
 using v8::Uint32;
 using v8::Value;
 
+namespace {
+bool IsVantaloomLoopbackAddress(const sockaddr* address) {
+  if (address->sa_family == AF_INET) {
+    const auto* ipv4 = reinterpret_cast<const sockaddr_in*>(address);
+    const auto* bytes =
+        reinterpret_cast<const unsigned char*>(&ipv4->sin_addr.s_addr);
+    return bytes[0] == 127;
+  }
+  if (address->sa_family == AF_INET6) {
+    const auto* ipv6 = reinterpret_cast<const sockaddr_in6*>(address);
+    const auto* bytes =
+        reinterpret_cast<const unsigned char*>(&ipv6->sin6_addr.s6_addr);
+    for (size_t index = 0; index < 15; index++) {
+      if (bytes[index] != 0) return false;
+    }
+    return bytes[15] == 1;
+  }
+  return false;
+}
