# Signing material — never commit (the keystore comes from GitHub Actions
# secrets at build time; see signing/README.md)
*.keystore
*.jks
key.properties

# Android / Gradle build output
android/.gradle/
android/build/
android/app/build/
android/local.properties
android/captures/
.gradle/

# The loomnet facade AAR is built by CI (gomobile bind) into app/libs/
android/app/libs/*.aar

# The compiled web export is staged into app assets by CI (source of truth: web/)
android/app/src/main/assets/*
!android/app/src/main/assets/README.md

node_modules/
dist/
.cursor/
.idea/
*.iml
local.properties
